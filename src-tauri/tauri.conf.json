{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MarkRefine",
  "version": "1.0.0",
  "identifier": "com.markrefine.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkRefine - Markdown 编辑器",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https: data: blob: file:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' asset: http://asset.localhost data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capabilities",
          "local": true,
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:allow-set-title",
            "core:window:allow-destroy",
            "dialog:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            {
              "identifier": "fs:default",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" }
              ]
            },
            "fs:allow-read-text-file",
            "fs:allow-write-text-file",
            "fs:allow-read-dir",
            "fs:allow-read-file",
            "fs:allow-write-file",
            "fs:allow-remove",
            "fs:allow-temp-write",
            "fs:allow-temp-read"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "assets/*",
      "assets/fonts/*",
      "example/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
